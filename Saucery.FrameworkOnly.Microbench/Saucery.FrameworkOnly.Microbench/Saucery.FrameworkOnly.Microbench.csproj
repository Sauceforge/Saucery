<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <OutputType>Exe</OutputType>
    <StartupObject>Saucery.FrameworkOnly.Microbench.Program</StartupObject>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <LangVersion>preview</LangVersion>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="BenchmarkDotNet" Version="0.15.8" />
    <PackageReference Include="BenchmarkDotNet.Diagnostics.Windows" Version="0.15.8" />
    <PackageReference Include="NUnitLite" Version="4.5.0" />
    <PackageReference Include="xunit.v3.runner.utility" Version="3.2.2" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Saucery.FrameworkOnly.Tests.NUnit\Saucery.FrameworkOnly.Tests.NUnit.csproj" />
    <ProjectReference Include="..\Saucery.FrameworkOnly.Tests.XUnit2\Saucery.FrameworkOnly.Tests.XUnit2.csproj" />
    <ProjectReference Include="..\Saucery.FrameworkOnly.Tests.XUnit3\Saucery.FrameworkOnly.Tests.XUnit3.csproj" />
  </ItemGroup>
</Project>
